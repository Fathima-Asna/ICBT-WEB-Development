<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>GlobeTrek Adventures</display-name>
    <description>Travel and Tourism Web Application — Pure HTML/CSS + Java/SQL Backend</description>

    <!-- ================================================================
         DEFAULT WELCOME FILE
         ================================================================ -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- ================================================================
         SERVLET DECLARATIONS
         ================================================================ -->

    <!-- Authentication Servlet: handles login and signup POST submissions -->
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.AuthServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <!-- Logout Servlet: invalidates session and redirects to login -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.LogoutServlet</servlet-class>
    </servlet>

    <!-- Booking Servlet: handles customer booking form submissions -->
    <servlet>
        <servlet-name>BookingServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.BookingServlet</servlet-class>
    </servlet>

    <!-- Admin Servlet: handles staff management and booking status updates -->
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.AdminServlet</servlet-class>
    </servlet>

    <!-- Customer Servlet: loads customer bookings and forwards to dashboard -->
    <servlet>
        <servlet-name>CustomerServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.CustomerServlet</servlet-class>
    </servlet>

    <!-- Staff Servlet: loads package listing and updates for staff -->
    <servlet>
        <servlet-name>StaffServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.StaffServlet</servlet-class>
    </servlet>

    <!-- Package Servlet: handles package dynamic search and lists -->
    <servlet>
        <servlet-name>PackageServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.PackageServlet</servlet-class>
    </servlet>

    <!-- Index Servlet: loads index.html dynamically to show active sessions -->
    <servlet>
        <servlet-name>IndexServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.IndexServlet</servlet-class>
    </servlet>

    <!-- Login Servlet: loads login.html dynamically to inject query param alerts -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.LoginServlet</servlet-class>
    </servlet>

    <!-- ================================================================
         SERVLET MAPPINGS
         ================================================================ -->

    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/auth</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>BookingServlet</servlet-name>
        <url-pattern>/book</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin/action</url-pattern>
        <url-pattern>/admin-dashboard.html</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>CustomerServlet</servlet-name>
        <url-pattern>/customer/dashboard</url-pattern>
        <url-pattern>/customer-dashboard.html</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>StaffServlet</servlet-name>
        <url-pattern>/staff/action</url-pattern>
        <url-pattern>/staff-dashboard.html</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>PackageServlet</servlet-name>
        <url-pattern>/packages</url-pattern>
        <url-pattern>/packages.html</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>IndexServlet</servlet-name>
        <url-pattern>/index.html</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login.html</url-pattern>
    </servlet-mapping>

    <!-- ================================================================
         FILTER DECLARATIONS
         AuthFilter protects all dashboard resources from unauthorized access.
         ================================================================ -->

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.globetrek.filter.AuthFilter</filter-class>
    </filter>

    <!-- Protect Customer Dashboard Template -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/customer-dashboard.html</url-pattern>
    </filter-mapping>

    <!-- Protect Customer Dashboard Servlet Route -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/customer/dashboard</url-pattern>
    </filter-mapping>

    <!-- Protect Staff Dashboard Template -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/staff-dashboard.html</url-pattern>
    </filter-mapping>

    <!-- Protect Staff Dashboard Servlet Route -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/staff/action</url-pattern>
    </filter-mapping>

    <!-- Protect Admin Dashboard Template -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin-dashboard.html</url-pattern>
    </filter-mapping>

    <!-- Protect Admin Action Servlet -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/action</url-pattern>
    </filter-mapping>

    <!-- Protect Booking Servlet -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/book</url-pattern>
    </filter-mapping>

    <!-- ================================================================
         SESSION CONFIGURATION
         ================================================================ -->
    <session-config>
        <!-- Session expires after 30 minutes of inactivity -->
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
    </session-config>

    <!-- ================================================================
         ERROR PAGES
         ================================================================ -->
    <error-page>
        <error-code>403</error-code>
        <location>/login.html?error=forbidden</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/index.html</location>
    </error-page>

</web-app>
