<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>GlobeTrek Adventures</display-name>
    <description>Travel and Tourism Web Application — Java EE Backend (Phase 2)</description>

    <!-- ================================================================
         DEFAULT WELCOME FILE
         ================================================================ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ================================================================
         SERVLET DECLARATIONS
         ================================================================ -->

    <!-- Authentication Servlet: handles login and signup POST submissions -->
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.AuthServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <!-- Logout Servlet: invalidates session and redirects to login -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.LogoutServlet</servlet-class>
    </servlet>

    <!-- Booking Servlet: handles customer booking form submissions -->
    <servlet>
        <servlet-name>BookingServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.BookingServlet</servlet-class>
    </servlet>

    <!-- Admin Servlet: handles staff management and booking status updates -->
    <servlet>
        <servlet-name>AdminServlet</servlet-name>
        <servlet-class>com.globetrek.servlet.AdminServlet</servlet-class>
    </servlet>

    <!-- ================================================================
         SERVLET MAPPINGS
         ================================================================ -->

    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/auth</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>BookingServlet</servlet-name>
        <url-pattern>/book</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>AdminServlet</servlet-name>
        <url-pattern>/admin/action</url-pattern>
    </servlet-mapping>

    <!-- ================================================================
         FILTER DECLARATIONS
         AuthFilter protects all dashboard JSPs from unauthorized access.
         ================================================================ -->

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.globetrek.filter.AuthFilter</filter-class>
    </filter>

    <!-- Protect Customer Dashboard -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/customer-dashboard.jsp</url-pattern>
    </filter-mapping>

    <!-- Protect Staff Dashboard -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/staff-dashboard.jsp</url-pattern>
    </filter-mapping>

    <!-- Protect Admin Dashboard -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin-dashboard.jsp</url-pattern>
    </filter-mapping>

    <!-- Protect Admin Action Servlet -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/action</url-pattern>
    </filter-mapping>

    <!-- Protect Booking Servlet -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/book</url-pattern>
    </filter-mapping>

    <!-- ================================================================
         SESSION CONFIGURATION
         ================================================================ -->
    <session-config>
        <!-- Session expires after 30 minutes of inactivity -->
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
        </cookie-config>
    </session-config>

    <!-- ================================================================
         ERROR PAGES
         ================================================================ -->
    <error-page>
        <error-code>403</error-code>
        <location>/login.jsp?error=forbidden</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/index.jsp</location>
    </error-page>

</web-app>
